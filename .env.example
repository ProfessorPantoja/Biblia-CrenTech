# --- Bíblia CrenTech: variáveis de ambiente ---
# Copie este arquivo para `.env.local` e preencha os valores.

# IA: chave da API do Groq (https://console.groq.com/keys)
VITE_GROQ_API_KEY=

# (Opcional) Modelos do Groq. Há defaults no código se ficar vazio.
# VITE_GROQ_MODEL=llama-3.3-70b-versatile
# VITE_GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
# VITE_GROQ_WHISPER_MODEL=whisper-large-v3

# (Opcional) Supabase — hoje sem uso direto no app.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
